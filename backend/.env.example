# JOBBER Pro - Environment Configuration
# Copy this file to .env and update with your actual values

# ======================
# ENVIRONMENT
# ======================
NODE_ENV=development
# Options: development, staging, production

# ======================
# SERVER
# ======================
PORT=3000
HOST=0.0.0.0

# ======================
# DATABASE (PostgreSQL)
# ======================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=jobber_pro
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# Database Pool Configuration (Optional - uses defaults if not set)
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_CONNECTION_TIMEOUT=2000
DB_IDLE_TIMEOUT=30000

# ======================
# SECURITY - JWT
# ======================
# CRITICAL: Generate strong random secrets (min 32 characters)
# Run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=GENERATE_A_RANDOM_32_CHAR_SECRET_HERE
JWT_REFRESH_SECRET=GENERATE_ANOTHER_DIFFERENT_32_CHAR_SECRET

# Token Expiry (Optional - defaults shown)
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ======================
# SECURITY - PASSWORDS
# ======================
# Bcrypt cost factor (10-15 recommended, higher = more secure but slower)
BCRYPT_ROUNDS=12

# ======================
# SECURITY - ENCRYPTION
# ======================
# CRITICAL: Generate strong random key (min 32 characters)
# Run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=GENERATE_A_RANDOM_32_CHAR_ENCRYPTION_KEY
COOKIE_SECRET=GENERATE_A_RANDOM_32_CHAR_COOKIE_SECRET

# ======================
# CORS
# ======================
# Frontend URL (adjust for your frontend)
CORS_ORIGIN=http://localhost:5173
# For production: https://yourdomain.com
# For multiple origins: https://app.yourdomain.com,https://admin.yourdomain.com

# ======================
# RATE LIMITING
# ======================
# Global rate limiting (Optional - uses defaults if not set)
RATE_LIMIT_WINDOW_MS=900000
# 900000 = 15 minutes

RATE_LIMIT_MAX_REQUESTS=100
# Maximum requests per window

AUTH_RATE_LIMIT_MAX=5
# Maximum auth attempts per window

# ======================
# EMAIL (SMTP)
# ======================
# Required for production, optional for development
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
EMAIL_FROM=noreply@jobber.pro

# For Gmail: Use App-Specific Password
# For SendGrid: Use API key as password
# For AWS SES: Use SMTP credentials

# ======================
# REDIS (Optional)
# ======================
# For distributed rate limiting and caching
# Leave empty to use in-memory storage
REDIS_URL=redis://localhost:6379

# For Redis Cloud:
# REDIS_URL=redis://username:password@host:port

# ======================
# MONITORING (Optional)
# ======================
# Sentry for error tracking
SENTRY_DSN=https://your-sentry-dsn-here

# PostHog for analytics
POSTHOG_API_KEY=your-posthog-api-key-here

# ======================
# LOGGING
# ======================
LOG_LEVEL=info
# Options: error, warn, info, debug

# ======================
# FEATURE FLAGS (Optional)
# ======================
ENABLE_SWAGGER=true
ENABLE_METRICS=true
ENABLE_AUDIT_LOGGING=true

# ======================
# PRODUCTION SETTINGS
# ======================
# Only set these in production

# Session Configuration
# SESSION_SECRET=generate-another-random-secret-for-sessions

# SSL/TLS
# FORCE_HTTPS=true
# SSL_CERT_PATH=/path/to/cert.pem
# SSL_KEY_PATH=/path/to/key.pem

# Database SSL
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=false

# ======================
# DEVELOPMENT HELPERS
# ======================
# Enable detailed logging in development
# DEBUG=express:*,knex:*

# Skip email sending in development (logs to console)
# SKIP_EMAIL=true

# ======================
# NOTES
# ======================
# 1. NEVER commit .env file to git
# 2. Use different secrets for each environment
# 3. Rotate secrets regularly in production
# 4. Store production secrets in a secure vault (AWS Secrets Manager, etc.)
# 5. Minimum secret length: 32 characters
# 6. Use strong random generators for all secrets

# ======================
# QUICK SETUP COMMANDS
# ======================
# Generate all secrets at once:
# node -e "const crypto = require('crypto'); console.log('JWT_SECRET=' + crypto.randomBytes(32).toString('hex')); console.log('JWT_REFRESH_SECRET=' + crypto.randomBytes(32).toString('hex')); console.log('ENCRYPTION_KEY=' + crypto.randomBytes(32).toString('hex')); console.log('COOKIE_SECRET=' + crypto.randomBytes(32).toString('hex'));"
