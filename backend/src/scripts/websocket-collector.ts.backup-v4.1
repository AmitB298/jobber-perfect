//  SECTION 13 — DEAD MAN'S SWITCH
// ════════════════════════════════════════════════════════════════════════════

function armDeadMan(onTrigger:()=>void):NodeJS.Timeout{
  return setInterval(()=>{
    if(isReconnecting)return;if(!isMarketHours())return;
    if(Date.now()-lastTick>90000){process.stdout.write('\n💀 [DEAD MAN] No ticks 90s — reconnecting\n');onTrigger();}
  },1000);
}

// ════════════════════════════════════════════════════════════════════════════
//  SECTION 14 — LOGIN
// ════════════════════════════════════════════════════════════════════════════

interface LoginResult{feedToken:string;clientCode:string;apiKey:string;service:any;}

async function loginToAngel(maxAttempts=5):Promise<LoginResult>{
  for(let attempt=1;attempt<=maxAttempts;attempt++){
    process.stdout.write(`🔐 [LOGIN] Attempt ${attempt}/${maxAttempts}...\n`);
    try{
      const svc=createAngelOneService();
      const result=await svc.login();
      if(result.success){
        const clientCode=process.env.ANGEL_CLIENT_CODE||'';
        process.stdout.write(`✅ [LOGIN] Success (client: ${clientCode})\n`);
        const s=svc as any;
        const feedToken:string=s.getFeedToken?.()??s.feedToken??s._feedToken??'';
        if(!feedToken)throw new Error('No feed token returned from service');
        return{feedToken,clientCode,apiKey:process.env.ANGEL_API_KEY||'',service:svc};
      }
      const msg=result.message||'Login failed';
      process.stderr.write(`❌ [LOGIN] Failed: ${msg}\n`);
      if(/too many|session|limit|blocked|forbidden/i.test(msg)&&attempt<maxAttempts){
        process.stdout.write('⚠️  Rate-limit — waiting 90s\n');await sleep(90000);continue;
      }
    }catch(e:any){process.stderr.write(`❌ [LOGIN] Error: ${e.response?.data?.message||e.message}\n`);}
    if(attempt<maxAttempts){const w=[0,5,10,15,20][attempt]??20;process.stdout.write(`   Retry in ${w}s\n`);await sleep(w*1000);}
  }
  throw new Error(`Login failed after ${maxAttempts} attempts`);
}

// ════════════════════════════════════════════════════════════════════════════
//  SECTION 15 — ONE SESSION
// ════════════════════════════════════════════════════════════════════════════

async function runSession():Promise<void>{
  const{feedToken,clientCode,apiKey,service}=await loginToAngel(5);

  process.stdout.write('\n🗄️  Verifying database...\n');
  await pool.query('SELECT 1');
  process.stdout.write('✅ Database ready\n');

  // ── Load NIFTY options ─────────────────────────────────────────────────
  // Filter by trading_symbol regex (most reliable — always ends in CE/PE).
  // Do NOT rely on instrumenttype field — Angel One uses 'OPTIDX', 'CE', 'PE',
  // 'OPT' etc. inconsistently across API versions and CDN JSON.
  // CDN fallback runs whenever getSymbolMaster() returns 0 results (not just throws).
  process.stdout.write('\n📋 Loading NIFTY options...\n');
  let niftyOpts:any[]=[];

  const NIFTY_OPT_RE=/^NIFTY\d{2}[A-Z]{3}\d{2,4}\d+(CE|PE)$/;
  function filterNiftyOpts(list:any[]):any[]{
    return list.filter((i:any)=>{
      const ts:string=i.trading_symbol||i.tradingsymbol||i.symbol||'';
      return NIFTY_OPT_RE.test(ts);
    });
  }

  // Attempt 1: getSymbolMaster()
  try{
    const instr:any[]=await service.getSymbolMaster?.()??[];
    if(instr.length>0){
      niftyOpts=filterNiftyOpts(instr);
      if(niftyOpts.length===0){
        process.stdout.write(`⚠️  getSymbolMaster returned ${instr.length} rows but 0 matched NIFTY options pattern\n`);
        const s=instr.slice(0,2).map((i:any)=>JSON.stringify(i)).join('\n   ');
        process.stdout.write(`   Sample: ${s}\n`);
      }
    } else {
      process.stdout.write('⚠️  getSymbolMaster returned empty array — trying CDN\n');
    }
  }catch(e:any){
    process.stdout.write(`⚠️  getSymbolMaster threw: ${e.message} — trying CDN\n`);
  }

  // Attempt 2: CDN — always run if attempt 1 got 0 results
  if(niftyOpts.length===0){
    process.stdout.write('📥 Fetching from Angel One CDN...\n');
    try{
      const raw:any[]=await new Promise((res,rej)=>{
        const req=https.get(
          'https://margincalculator.angelbroking.com/OpenAPI_File/files/OpenAPIScripMaster.json',
          (r:any)=>{let d='';r.on('data',(c:any)=>d+=c);r.on('end',()=>{try{res(JSON.parse(d));}catch(err){rej(err);}});}
        );
        req.on('error',rej);
        req.setTimeout(20000,()=>{req.destroy();rej(new Error('CDN timeout'));});
      });
      process.stdout.write(`✅ CDN: ${raw.length} total instruments\n`);
      niftyOpts=filterNiftyOpts(raw);
      if(niftyOpts.length===0){
        // Print sample to diagnose field names in this CDN response
        const nfo=raw.filter((i:any)=>i.exch_seg==='NFO'||i.exchange==='NFO').slice(0,5);
        process.stdout.write(`❌ Still 0 NIFTY options. NFO sample fields:\n`);
        for(const s of nfo) process.stdout.write(`   ${JSON.stringify(s)}\n`);
      }
    }catch(e2:any){
      process.stdout.write(`❌ CDN failed: ${e2.message}\n`);
    }
  }

  process.stdout.write(`✅ ${niftyOpts.length} NIFTY options loaded\n`);
  if(niftyOpts.length>0){
    const s=niftyOpts.slice(0,3).map((i:any)=>`${i.token}→${i.trading_symbol||i.tradingsymbol||i.symbol}`).join(' | ');
    process.stdout.write(`📋 Sample: ${s}\n`);
  }

  const ws=new AngelWebSocket(feedToken,clientCode,apiKey);

  return new Promise<void>((resolve,reject)=>{
    let aborted=false;
    let deadMan:NodeJS.Timeout|null=null;
    let vixTimer:NodeJS.Timeout|null=null;

    const abort=(reason:string)=>{
      if(aborted)return;aborted=true;isReconnecting=true;
      if(deadMan){clearInterval(deadMan);deadMan=null;}
      if(vixTimer){clearInterval(vixTimer);vixTimer=null;}
      try{ws.disconnect?.();}catch(_){}
      spoofingDetector.reset();
      reason==='dead-man'?resolve():reject(new Error(reason));
    };

    ws.on('tick',handleTick);
    ws.on('error',(err:Error)=>process.stderr.write(`❌ [WS] ${err.message}\n`));
    ws.on('close',(code:number)=>{if(!aborted)abort(`ws-closed-${code}`);});

    ws.connect().then(()=>{
      process.stdout.write('\n✅ WebSocket streaming active\n\n');

      // ── Index subscriptions ──────────────────────────────────────────────
      ws.subscribe?.([{token:'99926000',symbol:'NIFTY',exchange:'NSE'}]);

      // Token 99926017 = India VIX (official Angel One token)
      ws.subscribe?.([{token:'99926017',symbol:'India VIX',exchange:'NSE'}]);

      // ── Options chain subscription ───────────────────────────────────────
      // FIX #1: Use trading_symbol FIRST (full parseable name like NIFTY06MAR2624500CE).
      //         i.symbol from the CDN is always the generic "NIFTY" for all options —
      //         if it were used, every tick would arrive with symbol="NIFTY", parseOpt()
      //         would return null, and the entire chain would be silently dropped.
      //
      // Also handle both field-name variants that appear in different Angel One responses:
      //   - OpenAPIScripMaster.json:  uses "trading_symbol" (snake_case)
      //   - getSymbolMaster() API:    uses "tradingsymbol"  (camelCase, no underscore)
      if(niftyOpts.length>0){
        ws.subscribe?.(niftyOpts.map((i:any)=>({
          token: i.token,
          symbol: i.trading_symbol || i.tradingsymbol || i.symbol,  // ← FIX #1
          exchange: i.exch_seg || 'NFO',
        })));
        process.stdout.write(`✅ Subscribed to ${niftyOpts.length} NIFTY option tokens\n`);
      } else {
        process.stdout.write('⚠️  No NIFTY options to subscribe — chain will be empty\n');
      }

      deadMan=armDeadMan(()=>abort('dead-man'));
      vixTimer=setInterval(flushVix,1000);
    }).catch((err:Error)=>abort(err.message));
  });
}

// ════════════════════════════════════════════════════════════════════════════
//  SECTION 16 — OUTER LOOP + MAIN
// ════════════════════════════════════════════════════════════════════════════

async function main():Promise<void>{
  let shuttingDown=false,attempt=0;
  const display=startDisplay();

  const shutdown=async()=>{
    if(shuttingDown)return;shuttingDown=true;
    process.stdout.write('\n⏹️  Shutting down...\n');
    clearInterval(display);
    while(writeQ.length>0){await flushDB();await sleep(50);}
    await pool.end();
    process.stdout.write('✅ Shutdown complete\n');process.exit(0);
  };

  process.on('SIGINT',shutdown);process.on('SIGTERM',shutdown);
  process.on('uncaughtException',(e)=>process.stderr.write(`💥 [UNCAUGHT] ${e.message}\n`));
  process.on('unhandledRejection',(r)=>process.stderr.write(`💥 [UNHANDLED] ${String(r)}\n`));

  // Start spoof WS server once — survives session reconnects
  startSpoofDashboardWS();
  // Wire detector → router once — survives reconnects
  spoofingDetector.onAlert(routeSpoofAlert);

  process.stdout.write(`📡 Spoof alerts → alerts/alerts_${getISTDate()}.jsonl\n`);
  process.stdout.write(`📡 Telegram: ${TG_TOKEN?'✅ configured':'⚠️  not set'}\n`);
  process.stdout.write(`📡 WS feed: ws://localhost:${WS_PORT}\n\n`);

  while(!shuttingDown){
    attempt++;isReconnecting=true;
    try{await runSession();}
    catch(err:any){process.stderr.write(`\n❌ [OUTER] Session crashed: ${err.message}\n`);}
    if(shuttingDown)break;
    const wait=Math.max(65,Math.min(attempt*15,180));
    process.stdout.write(`🔄 Restarting in ${wait}s...\n`);
    await sleep(wait*1000);
  }
}

