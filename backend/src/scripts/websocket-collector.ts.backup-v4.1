function sleep(ms:number){return new Promise<void>(r=>setTimeout(r,ms));}
function safeN(v:any):number|null{const n=Number(v);if(!n||isNaN(n)||n<0||n>1e12)return null;return n;}
function monthNum(a:string):string{const m:Record<string,string>={JAN:'01',FEB:'02',MAR:'03',APR:'04',MAY:'05',JUN:'06',JUL:'07',AUG:'08',SEP:'09',OCT:'10',NOV:'11',DEC:'12'};return m[a.toUpperCase()]||'01';}

/**
 * parseOpt — FIX #2
 * Now handles BOTH 2-digit and 4-digit year formats from Angel One CDN:
 *   Standard:  NIFTY06MAR2624500CE   (year=26,  2-digit)
 *   Rare:      NIFTY06MAR202624500CE (year=2026, 4-digit)
 * The regex captures (\d{2,4}) for the year portion so both forms match.
 */
function parseOpt(sym:string):{expiry:string;strike:number;optionType:string}|null{
  // Matches: NIFTY + DD + MMM + YY|YYYY + strike + CE|PE
  const m=sym.match(/NIFTY(\d{2}[A-Z]{3}\d{2,4})(\d+(?:\.\d+)?)(CE|PE)/);
  if(!m)return null;
  const s=parseFloat(m[2].replace(/\.00$/,''));
  if(s<1000||s>50000)return null;
  return{expiry:m[1],strike:s,optionType:m[3]};
}

function isMarketHours():boolean{
  const ist=new Date(new Date().toLocaleString('en-US',{timeZone:'Asia/Kolkata'}));
  const d=ist.getDay();if(d===0||d===6)return false;
  const m=ist.getHours()*60+ist.getMinutes();return m>=555&&m<=930;
}

/**
 * parseExpiryToDate — FIX #3
 * Safely converts the expiry string captured by parseOpt into a YYYY-MM-DD
 * date string for DB storage, handling both 2-digit and 4-digit year formats.
 *
 *   "06MAR26"   → "2026-03-06"
 *   "06MAR2026" → "2026-03-06"
 */
function parseExpiryToDate(expiry:string):string{
  const day=expiry.slice(0,2);
  const mon=monthNum(expiry.slice(2,5));
  // Year is everything after the 3-char month code
  const yrRaw=expiry.slice(5);
  const yr=yrRaw.length===2?`20${yrRaw}`:yrRaw;
  return`${yr}-${mon}-${day}`;
}

