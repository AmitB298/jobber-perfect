{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "../dist-electron",
    "module": "commonjs",
    "target": "ES2020",
    "lib": [
      "ES2020"
    ],
    "moduleResolution": "node",
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "strict": true
  },
  "include": [
    "**/*"
  ]
}
