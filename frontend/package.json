{
  "name": "jobber-pro",
  "version": "1.0.0",
  "description": "Professional NIFTY 50 Options Analysis Platform",
  "main": "dist-electron/main/index.js",
  "author": "Your Company",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "vite",
    "dev:vite": "vite",
    "dev:electron": "tsc -p electron/tsconfig.json && electron .",
    "build": "tsc -p electron/tsconfig.json && vite build",
    "build:win": "npm run build && electron-builder --win --x64",
    "build:mac": "npm run build && electron-builder --mac",
    "build:linux": "npm run build && electron-builder --linux",
    "package": "electron-builder --dir",
    "dist": "electron-builder",
    "test": "vitest run",
    "lint": "eslint src --ext .ts,.tsx --fix",
    "start": "vite preview"
  },
  "dependencies": {
    "@headlessui/react": "^1.7.17",
    "@heroicons/react": "^2.1.0",
    "@sentry/electron": "^4.15.0",
    "@tanstack/react-query": "^5.14.0",
    "@types/pg": "^8.18.0",
    "ag-grid-community": "^31.0.0",
    "ag-grid-react": "^31.0.0",
    "axios": "^1.6.2",
    "cross-env": "^7.0.3",
    "date-fns": "^3.0.0",
    "dayjs": "^1.11.10",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.7",
    "immer": "^10.0.3",
    "keytar": "^7.9.0",
    "lucide-react": "^0.294.0",
    "node-machine-id": "^1.1.12",
    "numeral": "^2.0.6",
    "pg": "^8.20.0",
    "pino": "^8.17.0",
    "pino-pretty": "^10.3.0",
    "posthog-node": "^3.5.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "recharts": "^2.10.0",
    "wait-on": "^7.2.0",
    "ws": "^8.15.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.10.4",
    "@types/numeral": "^2.0.5",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/recharts": "^1.8.29",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.2",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.3.3",
    "vite": "^5.0.7",
    "vite-plugin-electron": "^0.28.0"
  },
  "build": {
    "appId": "com.yourcompany.jobber",
    "productName": "JOBBER Pro",
    "directories": {
      "output": "release/${version}"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "artifactName": "${productName}-${version}-Setup.${ext}"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.finance"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build/icon.png",
      "category": "Finance"
    },
    "publish": {
      "provider": "github",
      "owner": "your-github-username",
      "repo": "jobber-desktop"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
